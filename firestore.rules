rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Attendance collection
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }
    
    // 2. Global Safety Net default-deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
